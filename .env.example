# Frontend
VITE_API_URL=http://localhost:3000

# Backend (server/.env or root .env)
DATABASE_URL=postgresql://user:pass@host/db
# Testy Vitest (server/npm test) — NIGDY na produkcję: cleanDb usuwa WSZYSTKICH userów i danych.
# Tylko na osobnym branchu Neon + wtedy:
# ALLOW_VITEST_DB_WIPE=yes
NEXTAUTH_SECRET=your-jwt-secret
# 32 bajty: openssl rand -hex 32  albo  openssl rand -base64 32
FINANCE_DATA_KEY=your-finance-data-key
NEXTAUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
RESEND_API_KEY=your-resend-api-key

# Web Push (powiadomienia o klimie) — wygeneruj: cd server && npx @pushforge/builder vapid
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_JWK={"kty":"EC","crv":"P-256",...}
PUSH_ADMIN_CONTACT=mailto:twoj@email.pl

# SmartThings (Faza 1) — JEDEN zestaw na całą apkę (nie per user).
# Z `smartthings apps:create` (OAuth-In App). Tokeny per user idą do bazy (smartthings_credentials), nie tu.
# Prod: ustaw przez `wrangler secret put`. Redirect URI globalny też w wrangler.toml [vars].
SMARTTHINGS_CLIENT_ID=your-smartthings-client-id
SMARTTHINGS_CLIENT_SECRET=your-smartthings-client-secret
SMARTTHINGS_REDIRECT_URI=http://localhost:3000/api/smartthings/callback
# DEV-ONLY: Personal Access Token do spike (server/scripts/smartthings-spike.mjs). Wygasa po 24h.
# NIE do produkcji — z https://account.smartthings.com/tokens. Możesz też ustawić doraźnie w shellu.
SMARTTHINGS_PAT=your-smartthings-pat-dev-only
